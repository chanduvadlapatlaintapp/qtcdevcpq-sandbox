<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>BIZ-72861: Check if Deal Desk Audit checkbox changed</description>
        <name>Check_Deal_Desk_Audit_Updated</name>
        <label>Check Deal Desk Audit Updated</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>No Update Needed</defaultConnectorLabel>
        <rules>
            <name>Deal_Desk_Audit_Changed</name>
            <conditionLogic>((1 AND 4) OR (3 AND 4)) AND 2</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Deal_Desk_Audit_Complete__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Quote__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Deal_Desk_Audit_Complete__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Deal_Desk_Audit_Complete__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Opportunity_Field</targetReference>
            </connector>
            <label>Deal Desk Audit Changed</label>
        </rules>
    </decisions>
    <description>BIZ-72861: Updates Opportunity field from Validation Checklist
BIZ-72861: Added checks for Validation record inserts in the Opportunity Update Decision element.</description>
    <environments>Default</environments>
