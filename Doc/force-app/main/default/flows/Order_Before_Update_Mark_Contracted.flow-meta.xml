<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Set_Contracted_True</name>
        <label>Set Contracted = True</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <assignmentItems>
            <assignToReference>$Record.SBQQ__Contracted__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <description>When an Order is updated and Status = Activated with the NetSuite Sales Order present and NetSuite Document Number populated, mark SBQQ__Contracted__c = true. Filters on NetSuite_Sales_order_Internal_Id__c (the source of the NetSuite_Sales_Order_URL__c formula) because Before-Save flows cannot reference formula fields. Fires once on transition into the qualifying state. Honors the Automation_Controls__c bypass framework.</description>
    <environments>Default</environments>
    <interviewLabel>Order Before Update - Mark Contracted {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Order Before Update - Mark Contracted</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_Contracted_True</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>NOT(
  {!$Setup.Automation_Controls__c.Active__c}
  &amp;&amp; {!$Setup.Automation_Controls__c.Bypass_Flows__c}
  &amp;&amp; {!$Setup.Automation_Controls__c.Order_Bypass__c}
  &amp;&amp; (
    ISBLANK({!$Setup.Automation_Controls__c.Data_Id__c})
    || CONTAINS({!$Setup.Automation_Controls__c.Data_Id__c}, {!$Record.Id})
  )
)
&amp;&amp; ISPICKVAL({!$Record.Status}, &quot;Activated&quot;)
&amp;&amp; NOT(ISBLANK({!$Record.NetSuite_Sales_order_Internal_Id__c}))
&amp;&amp; NOT({!$Record.SBQQ__Contracted__c})</filterFormula>
        <object>Order</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
