    <start>
        <locationX>144</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Bypass_the_flow</targetReference>
        </connector>
        <filterFormula>AND(
    NOT({!$Setup.Automation_Controls__c.Active__c} 
    &amp;&amp; {!$Setup.Automation_Controls__c.Bypass_Flows__c} 
    &amp;&amp; {!$Setup.Automation_Controls__c.Quoteline_Bypass__c} 
    &amp;&amp; (
        ISBLANK({!$Setup.Automation_Controls__c.Data_Id__c}) 
