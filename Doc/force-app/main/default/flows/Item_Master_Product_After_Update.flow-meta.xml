<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>When Item Master Product TaxCode__c is updated, propagate the new tax code to AVA_SFCPQ__TaxCode__c and SBQQ__TaxCode__c on all related Product2 records. Handles null propagation (clearing tax code). BIZ-79705.</description>
    <environments>Default</environments>
    <interviewLabel>Item Master Product : After Update {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Item Master Product : After Update</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Update AVA_SFCPQ__TaxCode__c and SBQQ__TaxCode__c on all related Product2 records to match the updated Item Master TaxCode__c value. Handles null (cleared tax code) propagation automatically.</description>
        <name>Update_Product_Tax_Codes</name>
        <label>Update Product Tax Codes</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Item_Master_Product__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>AVA_SFCPQ__TaxCode__c</field>
            <value>
                <elementReference>$Record.TaxCode__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>SBQQ__TaxCode__c</field>
            <value>
                <elementReference>$Record.TaxCode__c</elementReference>
            </value>
        </inputAssignments>
        <object>Product2</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Product_Tax_Codes</targetReference>
        </connector>
        <filterFormula>({!$Record.TaxCode__c} &lt;&gt; {!$Record__Prior.TaxCode__c})
&amp;&amp; NOT(
  {!$Setup.Automation_Controls__c.Active__c}
  &amp;&amp; {!$Setup.Automation_Controls__c.Bypass_Flows__c}
  &amp;&amp; {!$Setup.Automation_Controls__c.ItemMasterProduct_ByPass__c}
  &amp;&amp; (
      ISBLANK({!$Setup.Automation_Controls__c.Data_Id__c})
      || (NOT(ISBLANK({!$Setup.Automation_Controls__c.Data_Id__c}))
          &amp;&amp; CONTAINS({!$Setup.Automation_Controls__c.Data_Id__c}, {!$Record.Id}))
  )
)</filterFormula>
        <object>Item_Master_Product__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
