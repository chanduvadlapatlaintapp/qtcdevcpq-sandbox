        <formula>AND( PRIORVALUE(SBQQ__Opportunity__c) = &apos;&apos;, ISCHANGED( SBQQ__Opportunity__c ),  ISPICKVAL(SBQQ__Opportunity__r.Fulfilling_Entity__c, &apos;Intapp&apos;) )</formula>
