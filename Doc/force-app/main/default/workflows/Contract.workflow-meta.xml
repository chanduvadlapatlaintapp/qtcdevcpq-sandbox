    <rules>
        <fullName>Rule Code%3A CTR-015Exxx</fullName>
        <actions>
            <name>Jason_s_Email_Alert</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <description>Rule Code: CTR-015Exxx
Stephen&apos;s Email Notification
Sends an email notification to Jason whenever Stephen is the approver on a record</description>
        <formula>AND(   ISCHANGED(Approval_Status__c),   Approval_Status__c=&quot;Pending&quot;,   OR(      Approver_1__r.LastName=&quot;Robertson&quot;,      Approver_2__r.LastName=&quot;Robertson&quot;,      Approver_3__r.LastName=&quot;Robertson&quot;,      Approver_4__r.LastName=&quot;Robertson&quot;,      Approver_5__r.LastName=&quot;Robertson&quot;,      Approver_6__r.LastName=&quot;Robertson&quot;,      Exception_Approver_1__r.LastName=&quot;Robertson&quot;,      Exception_Approver_2__r.LastName=&quot;Robertson&quot;,      Exception_Approver_3__r.LastName=&quot;Robertson&quot;,      Exception_Approver_4__r.LastName=&quot;Robertson&quot;,      Exception_Approver_5__r.LastName=&quot;Robertson&quot; ) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
