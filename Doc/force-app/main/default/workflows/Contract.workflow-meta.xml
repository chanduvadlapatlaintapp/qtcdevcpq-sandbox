    <rules>
        <fullName>Rule Code%3A CTR-025Exxx</fullName>
        <active>true</active>
        <description>Rule Code: CTR-025Exxx
Contract Created Notification with Opportunity fulfilling entity = Intapp
Sends an email notification to sales op&apos;s that a contract has been created.</description>
        <formula>AND( NOT(ISBLANK( SBQQ__Opportunity__c )), ISPICKVAL(SBQQ__Opportunity__r.Fulfilling_Entity__c, &apos;Intapp&apos;) )</formula>
