<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>AI Quote Assistant</masterLabel>
    <description>AI-powered chat assistant for building quotes using natural language commands. Integrates with OpenAI for intelligent query processing.</description>
    <targets>
        <target>lightning__RecordPage</target>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__FlowScreen</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <property name="quoteId" type="String" label="Quote ID" description="The ID of the quote to work with"/>
            <property name="isDarkMode" type="Boolean" label="Dark Mode" default="true" description="Enable dark mode theme"/>
        </targetConfig>
        <targetConfig targets="lightning__AppPage,lightning__HomePage">
            <property name="quoteId" type="String" label="Quote ID" description="The ID of the quote to work with"/>
            <property name="isDarkMode" type="Boolean" label="Dark Mode" default="true" description="Enable dark mode theme"/>
        </targetConfig>
        <targetConfig targets="lightning__FlowScreen">
            <property name="quoteId" type="String" label="Quote ID" description="The ID of the quote to work with" role="inputOnly"/>
            <property name="isDarkMode" type="Boolean" label="Dark Mode" default="true" description="Enable dark mode theme"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>