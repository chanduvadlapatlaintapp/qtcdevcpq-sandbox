    /**
     * @description Non-Finalize OSA - default suffix branch
     */
    @IsTest
    public static void testGenerateCongaUrlDefaultSuffixNonFinalize() {
        SBQQ__Quote__c q = getQuoteByOSA('OSA-0001');

        Test.startTest();

            String url = CongaUrlService.generateCongaURL(q.Id);

        Test.stopTest();

        System.assertNotEquals(true, startsWithError(url),
            'Uh oh, generateCongaURL returned an error unexpectedly: ' + url);

        // Core tokens that should be present
        System.assert(url.contains('QueryId='),
            'Uh oh, expected QueryId parameter missing.');
        System.assert(url.contains('TemplateId=' + System.Label.OSA_Document_Key),
            'Uh oh, expected TemplateId using OSA_Document_Key label missing.');
        System.assert(url.contains('&OFN=') || url.contains('&OFN='),
            'Uh oh, expected OFN parameter missing.');
        System.assert(url.contains('_Bundle'),
            'Uh oh, expected default suffix with _Bundle missing.');
        System.assert(url.contains(q.OSA_Number__c),
            'Uh oh, expected OSA number in filename missing.');
        System.assert(url.contains(q.Line_of_Business__c),
            'Uh oh, expected Line of Business in filename missing.');
        System.assert(url.contains('_v3'),
            'Uh oh, expected version token in filename missing.');
    }

    /**
     * @description Finalize OSA + Watermark + Amend - should include DV0=DRAFT and _Amendment_
     */
    @IsTest
    public static void testGenerateCongaUrlFinalizeWatermarkAmend() {
        SBQQ__Quote__c q = getQuoteByOSA('OSA-0001');
        System.assertEquals(true, String.isNotBlank(q.Bill_To_Address__c), q.Bill_To_Address__r.Status__c);
        System.assertEquals(true, String.isNotBlank(q.Ship_To_Address__c), q.Ship_To_Address__r.Status__c);
        System.assertEquals('Verification Approved', q.Bill_To_Address__r.Status__c, 'Bill To Address Status check');
        System.assertEquals('Verification Approved', q.Ship_To_Address__r.Status__c, 'Ship To Address Status check');
        Test.startTest();
            q.Quote_Stage__c = QuoteConstants.STATUS_FINALIZE_OSA;
            q.SBQQ__WatermarkShown__c = true;
            q.SBQQ__Type__c = QuoteConstants.TYPE_AMENDMENT;
            q.Version__c = '2';
            update q;
            String url = CongaUrlService.generateCongaURL(q.Id);

        Test.stopTest();

        System.assertNotEquals(true, startsWithError(url),
            'Uh oh, generateCongaURL returned an error unexpectedly: ' + url);

        System.assert(url.contains('DV0=DRAFT'),
            'Uh oh, expected DV0=DRAFT watermark token missing.');
        System.assert(url.contains('_Amendment_'),
            'Uh oh, expected _Amendment_ token missing.');
        System.assert(url.contains(q.OSA_Number__c) && url.contains(q.Line_of_Business__c) && url.contains('_v2'),
            'Uh oh, expected filename tokens missing.');
    }

