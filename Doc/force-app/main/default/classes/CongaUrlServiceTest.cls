    /**
     * @description When a quote line product matches a CMT entry and the master file exists in the org,
     * generateQuoteTerms should copy the file to the Quote (new ContentVersion via FirstPublishLocationId),
     * resulting in a ContentDocumentLink on the Quote with the matching title.
     */
    @IsTest
    public static void testGenerateQuoteTermsLinksFileToQuote() {
        SBQQ__Quote__c q = getQuoteByOSA('OSA-0001');

        // Master file in the org (not yet on the Quote)
        ContentVersion master = new ContentVersion(
            Title = 'Celeste Terms',
            PathOnClient = 'CelesteTerms.pdf',
            VersionData = Blob.valueOf('Test PDF Content'),
            IsMajorVersion = true
        );
        insert master;

        CongaUrlService.testProductDocumentMappingOverride = new Map<String, String>{
            'TEST-001' => 'Celeste Terms'
        };

        Test.startTest();
            String result = CongaUrlService.generateQuoteTerms(q.Id);
        Test.stopTest();

        System.assertNotEquals(true, startsWithError(result),
            'Uh oh, generateQuoteTerms returned an error unexpectedly: ' + result);

        // A quote-owned copy should now be linked — match by title, not by master ContentDocumentId
        List<ContentDocumentLink> links = [
            SELECT Id FROM ContentDocumentLink
            WHERE LinkedEntityId = :q.Id
            AND ContentDocument.Title = 'Celeste Terms'
        ];
        System.assertEquals(1, links.size(),
            'Uh oh, expected exactly one ContentDocumentLink for the Celeste file on the Quote.');
    }

