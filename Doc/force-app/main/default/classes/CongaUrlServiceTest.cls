    /**
     * @description Fetch a quote by name for scenario isolation
     * @param nameVal Name of the SBQQ__Quote__c
     * @return SBQQ__Quote__c record
     */
    private static SBQQ__Quote__c getQuoteByOSA(String nameVal) {
        return [
            SELECT Id, Name, OSA_Number__c, Line_of_Business__c, Quote_Stage__c, SBQQ__WatermarkShown__c, Version__c,
                Bill_To_Address__c, Ship_To_Address__c, SBQQ__Type__c, SBQQ__Account__c, SBQQ__Account__r.Account_Short_Name__c,
                Bill_To_Address__r.Status__c, Ship_To_Address__r.Status__c
            FROM SBQQ__Quote__c
            WHERE OSA_Number__c = :nameVal
            LIMIT 1
        ];
    }

    /**
     * @description Checks if given string starts with 'ERROR : ' prefix
     * @param val String to check
     * @return true if starts with 'ERROR : ', false otherwise
     */
    private static Boolean startsWithError(String val) {
        return val != null && val.startsWith('ERROR : ');
    }
