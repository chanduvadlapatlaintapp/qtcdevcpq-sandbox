    /**
     * @description When a quote line product matches a Product_Document_Mapping__mdt entry
     * and the file has already been copied to the Quote (via generateQuoteTerms),
     * the generated URL should include AttachmentId= before OFN=.
     * Simulates the post-generateQuoteTerms state by uploading directly against the Quote.
     */
    @IsTest
    public static void testGenerateCongaUrlIncludesAttachmentId() {
        SBQQ__Quote__c q = getQuoteByOSA('OSA-0001');

        // Simulate the quote-owned copy that linkCelesteFileToQuote would create
        ContentVersion cv = new ContentVersion(
            Title = 'Celeste Terms',
            PathOnClient = 'CelesteTerms.pdf',
            VersionData = Blob.valueOf('Test PDF Content'),
            IsMajorVersion = true,
            FirstPublishLocationId = q.Id
        );
        insert cv;
        String expectedDocId = [SELECT ContentDocumentId FROM ContentVersion WHERE Id = :cv.Id].ContentDocumentId;

        // Inject product-code -> document-title mapping (mirrors what CMT record would contain)
        CongaUrlService.testProductDocumentMappingOverride = new Map<String, String>{
            'TEST-001' => 'Celeste Terms'
        };

        Test.startTest();
            String url = CongaUrlService.generateCongaURL(q.Id);
        Test.stopTest();

        System.assertNotEquals(true, startsWithError(url),
            'Uh oh, generateCongaURL returned an error unexpectedly: ' + url);
        System.assert(url.contains('AttachmentId=' + expectedDocId),
            'Uh oh, expected AttachmentId=' + expectedDocId + ' in URL: ' + url);
        System.assert(url.indexOf('AttachmentId=') < url.indexOf('OFN='),
            'Uh oh, AttachmentId should appear before OFN in URL: ' + url);
    }

