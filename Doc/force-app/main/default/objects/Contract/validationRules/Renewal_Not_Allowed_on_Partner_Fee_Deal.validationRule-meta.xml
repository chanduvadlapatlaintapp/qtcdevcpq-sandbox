<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Renewal_Not_Allowed_on_Partner_Fee_Deal</fullName>
    <active>true</active>
    <errorConditionFormula>ISPICKVAL(Deal_Type__c, &apos;Partner_Fee&apos;) &amp;&amp; ( SBQQ__RenewalForecast__c  = true ||  SBQQ__RenewalQuoted__c  = true)</errorConditionFormula>
