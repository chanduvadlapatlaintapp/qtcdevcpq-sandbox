<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>List_Price_Discount_Percent__c</fullName>
    <description>BIZ-62795</description>
    <formula>IF(
CPQ_List_Price__c = 0,
0,
(CPQ_List_Price__c - Net_Price_Month__c)/CPQ_List_Price__c
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Total discount from list price after factoring in one-time credits.</inlineHelpText>
    <label>Total Discount %</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <type>Percent</type>
</CustomField>
