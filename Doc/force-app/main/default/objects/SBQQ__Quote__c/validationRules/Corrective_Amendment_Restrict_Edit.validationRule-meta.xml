<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Corrective_Amendment_Restrict_Edit</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISCHANGED(Corrective_Amendment__c),
    NOT(CONTAINS($Label.Corrective_Amendment_Editors, $User.Email))
)</errorConditionFormula>
    <errorDisplayField>Corrective_Amendment__c</errorDisplayField>
    <errorMessage>Only authorized users can modify the Corrective Amendment flag.</errorMessage>
</ValidationRule>
