<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Quote_OSA_Stage_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Quote_Stage__c,&apos;Finalize OSA&apos;),NOT(ISPICKVAL(Renewal_Quote_Type__c,&apos;Auto-Renewal&apos;)),
NOT(ISPICKVAL(Deal_Type__c,&apos;Cancellation&apos;)),
ISPICKVAL(Contract_Master_Terms__c,&quot;&quot;)
)</errorConditionFormula>
    <errorMessage>Contract Master Terms must be populated.</errorMessage>
</ValidationRule>
