<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>User_Same_as_Approver__c</fullName>
    <description>This field check if approver is same as logged in user. It is being used in My Open Approval Report filters.</description>
    <formula>sbaa__Approver__r.sbaa__User__r.Id == $User.Id</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>User Same as Approver</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
