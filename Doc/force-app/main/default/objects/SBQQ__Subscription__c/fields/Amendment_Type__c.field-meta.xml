<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Amendment_Type__c</fullName>
    <description>Classifies the amendment based on subscription quantity sign: Positive (increase or new addition), Negative (decrease), or Neutral (zero).</description>
    <externalId>false</externalId>
    <formula>IF(SBQQ__Quantity__c &gt; 0, &quot;Positive&quot;,
   IF(SBQQ__Quantity__c &lt; 0, &quot;Negative&quot;, &quot;Neutral&quot;))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Amendment Type</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
