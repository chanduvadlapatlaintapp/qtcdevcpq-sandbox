<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Segment_Months__c</fullName>
    <externalId>false</externalId>
    <formula>IF(DAY(SBQQ__SegmentEndDate__c) &lt; DAY(SBQQ__SegmentStartDate__c),
(MONTH(SBQQ__SegmentEndDate__c)) + (12*(YEAR(SBQQ__SegmentEndDate__c)-(YEAR(SBQQ__SegmentStartDate__c)))) -
(MONTH(SBQQ__SegmentStartDate__c)),
(MONTH(SBQQ__SegmentEndDate__c)) + (12*(YEAR(SBQQ__SegmentEndDate__c)-YEAR(SBQQ__SegmentStartDate__c))) -
MONTH(SBQQ__SegmentStartDate__c) + 1
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Segment Months</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
