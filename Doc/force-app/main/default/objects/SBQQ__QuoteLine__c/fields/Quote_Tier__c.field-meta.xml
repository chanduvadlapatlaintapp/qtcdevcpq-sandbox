<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Quote_Tier__c</fullName>
    <description>BIZ-59408 - Updating the formula to account for FY25 GTM Motion Tier enablement</description>
    <externalId>false</externalId>
    <formula>IF(  
    OR(CONTAINS(SBQQ__Quote__r.Price_book_rule__c, &quot;FY24&quot;),CONTAINS(SBQQ__Quote__r.Price_book_rule__c, &quot;FY23&quot;),CONTAINS(SBQQ__Quote__r.Price_book_rule__c, &quot;FY22&quot;)), 
    &apos;Tier &apos;+SBQQ__Quote__r.Account_Quote_Tier__c , 
    TEXT(SBQQ__Quote__r.SBQQ__Account__r.GTM_Motion_Tier__c)
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Quote Tier</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
