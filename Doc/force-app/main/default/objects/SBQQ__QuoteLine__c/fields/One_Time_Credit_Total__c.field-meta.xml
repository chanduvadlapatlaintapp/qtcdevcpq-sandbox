<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>One_Time_Credit_Total__c</fullName>
    <description>Created to get One Time Credit Total for conga template per BIZ-45156</description>
    <externalId>false</externalId>
    <formula>IF( One_Time_Credit__c &gt; 0, One_Time_Credit__c * -1, 0)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>One Time Credit Total</label>
