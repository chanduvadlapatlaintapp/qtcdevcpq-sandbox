<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Validate_Service_End_Date</fullName>
    <active>true</active>
    <description>Created w.r.t BIZ-67907</description>
    <errorConditionFormula>AND(
SBQQ__EndDate__c &gt; ADDMONTHS(SBQQ__Quote__r.SBQQ__StartDate__c, SBQQ__Quote__r.SBQQ__SubscriptionTerm__c),
$Profile.Name &lt;&gt; &apos;System Administrator&apos;,
ISPICKVAL(SBQQ__Product__r.Product_Type__c, &apos;Services&apos;)
)</errorConditionFormula>
    <errorMessage>The End Date for the Services Products cannot be greater than the total period of the Contract</errorMessage>
</ValidationRule>
