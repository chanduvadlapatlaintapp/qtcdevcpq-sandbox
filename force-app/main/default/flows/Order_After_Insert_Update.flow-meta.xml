        <rules>
            <name>Is_Reduction_Order_Without_Original_Order_Id</name>
            <conditionLogic>1 AND (2 OR 3) AND 4 AND 5</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Original_Order_Id__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
