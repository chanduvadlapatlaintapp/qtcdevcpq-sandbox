    <description>Updated Hold Billing conditions. Changed event trigger and merged with Order Product : Before Insert or Update - V1
Added a extra condition to decision and Added condition to work for Invoice Plan BF
Added condition to skip migration quotes
BIZ-66420- Flow bypass logic</description>
    <environments>Default</environments>
    <formulas>
        <name>Billingtreatmentname</name>
        <dataType>String</dataType>
        <expression>&quot;Billing Treatment&quot; &amp; &quot; &quot; &amp; {!$Record.OrderItemNumber}</expression>
    </formulas>
    <formulas>
        <name>NullDatevalue</name>
        <dataType>Date</dataType>
        <expression>DATEVALUE(&quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>Overridenextbilldateformula</name>
        <dataType>Date</dataType>
        <expression>CASE(TEXT({!$Record.Order.SBQQ__PaymentTerm__c}),
 &quot;Net 7&quot;, ({!$Record.ServiceDate} - 37),
 &quot;Net 30&quot;, ({!$Record.ServiceDate} - 60), 
 &quot;Net 45&quot;, ({!$Record.ServiceDate} - 75),
&quot;Net 60&quot;, ({!$Record.ServiceDate} - 90),
&quot;Net 90&quot;, ({!$Record.ServiceDate} - 120),
&quot;Net 120&quot;, ({!$Record.ServiceDate} - 150),
{!$Record.ServiceDate})</expression>
    </formulas>
    <formulas>
        <name>Segment1nextbillingdate</name>
        <dataType>Date</dataType>
        <expression>IF(ISNULL({!$Record.Order.SBQQ__Quote__r.Override_Next_Billing_date__c}), DATEVALUE({!$Record.Order.ActivatedDate}), {!$Record.Order.SBQQ__Quote__r.Override_Next_Billing_date__c})</expression>
    </formulas>
    <formulas>
        <name>SegmentMonths</name>
        <dataType>Number</dataType>
        <expression>IF(DAY({!$Record.EndDate}) &lt; DAY({!$Record.ServiceDate}),
(MONTH({!$Record.EndDate})) + (12*(YEAR({!$Record.EndDate})-(YEAR({!$Record.ServiceDate})))) -
(MONTH({!$Record.ServiceDate})),
(MONTH({!$Record.EndDate})) + (12*(YEAR({!$Record.EndDate})-YEAR({!$Record.ServiceDate}))) -
MONTH({!$Record.ServiceDate}) + 1
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>SubsidiaryName</name>
        <dataType>String</dataType>
        <expression>IF((LEFT(TEXT({!$Record.Order.Subsidiary__c}), 1) = &quot;0&quot;), 
MID(TEXT({!$Record.Order.Subsidiary__c}), 2, 1), 
LEFT(TEXT({!$Record.Order.Subsidiary__c}), 2))</expression>
    </formulas>
