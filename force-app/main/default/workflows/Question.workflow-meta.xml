    <rules>
        <fullName>Rule Code%3A QSTN-001Exxx</fullName>
        <actions>
            <name>Notify_Customer_of_Intapp_Customer_Community_Reply</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <description>Rule Code: QSTN-001Exxx
Notify Customer of Question Reply
Sends an email notification to Customer when a reply to a question is received.</description>
        <formula>LastModifiedById &lt;&gt; CreatedById</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Rule Code%3A QSTN-002Exxx</fullName>
        <actions>
            <name>Notify_Support_of_Customer_Community_Question</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Question.CreatedDate</field>
            <operation>equals</operation>
            <value>TODAY</value>
        </criteriaItems>
        <description>Rule Code: QSTN-002Exxx
Notify Support of Question
Sends an email notification to Support when a question is posted.</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
