    <rules>
        <fullName>Rule Code%3A CASE-001xFxx</fullName>
        <actions>
            <name>Populate_CRD_Email</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Rule Code: CASE-001xFxx
Populate CRD Email
Populates CRD Email on Case object</description>
        <formula>TRUE</formula>
        <triggerType>onCreateOnly</triggerType>
    </rules>
    <rules>
        <fullName>Rule Code%3A CASE-018xxOx</fullName>
        <actions>
            <name>SendCaseToDTE</name>
            <type>OutboundMessage</type>
        </actions>
        <active>true</active>
        <description>Rule Code: CASE-018xxOx
UpdateCaseInDTE
Sends out an outbound message to update Case in DTE</description>
        <formula>ISNEW() || ( (ISCHANGED(AccountId) || ISCHANGED(Date_Closed__c) || ISCHANGED(IsClosed) || ISCHANGED(RecordTypeId) || ISCHANGED(Status) || ISCHANGED(Subject)) &amp;&amp; (Record_Type_Name__c &lt;&gt; &apos;Support Survey&apos; &amp;&amp; Record_Type_Name__c &lt;&gt; &apos;Survey&apos; &amp;&amp; Record_Type_Name__c &lt;&gt; &apos;FRU&apos; &amp;&amp; Record_Type_Name__c &lt;&gt; &apos;Procurement&apos; &amp;&amp; LEFT(Record_Type_Name__c, 14) &lt;&gt; &apos;Implementation&apos;))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Rule Code%3A CASE-019xFxx</fullName>
        <actions>
            <name>Update_Case_Owner_to_Unidentified</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <booleanFilter>1 OR 2 OR 3 OR 4 OR 5 OR 6 OR 7 OR 8</booleanFilter>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Error: Object reference not set to an instance of an object</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Error: Exception of type &apos;System.OutOfMemoryException&apos; was thrown</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Error: Attempted to read or write protected memory</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Error: A generic error occurred in GDI+</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Error: Cannot access a disposed object</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Error: Invoke or BeginInvoke cannot be called on a control until the window handle</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Error: Collection was modified</value>
        </criteriaItems>
        <criteriaItems>
            <field>Case.Subject</field>
            <operation>contains</operation>
            <value>Error: Index was out of range</value>
        </criteriaItems>
        <description>Rule Code: CASE-019xFxx
Assign Cases to Unidentified
SC-000048
Assigns cases to the unidentified queue; this is due to the fact that these cases are being generated by automatic error messages from the appliance and are cluttering the SFDC queue.</description>
        <triggerType>onCreateOnly</triggerType>
