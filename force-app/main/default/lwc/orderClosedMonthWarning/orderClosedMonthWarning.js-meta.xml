<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <description>BIZ-76541: Displays a warning banner on Orders where the Opportunity Closed Month does not match the current month.</description>
    <isExposed>true</isExposed>
    <masterLabel>Order Closed Month Warning</masterLabel>
    <targets>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <objects>
                <object>Order</object>
            </objects>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>